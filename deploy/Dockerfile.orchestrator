# flow-orchestrator — the UNTRUSTED per-run image (§11.1). One ephemeral
# container per run; it executes the S1–S12 machine and the claude-code agent.
#
# Derived from the R4-verified experiment image (~/.config/flow-experiment):
# node:22-slim + baked @anthropic-ai/claude-code, run with the §11.1 hardening
# flags (see docker-compose.yml / docker run invocation in cmd/flow-runner).
# The R4 experiment proved claude-code plan-billing auth survives this hardening.
#
# Claude credential: NOT baked in. The runner provisions it as a file into the
# container at run time (Model B, §11.5/§12) — the central service never sees it.

# Build the orchestrator entrypoint as a static Go binary so the untrusted
# runtime image carries no Go toolchain.
FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/flow-orchestrator ./cmd/flow-runner

FROM node:22-slim

# Base tooling + PHP/WordPress lint toolchain (#40). WordPress/PHP projects need
# `composer install` (S5 env-bootstrap) and linting (php -l, PHPCS + WPCS) to run
# inside the hardened container. The toolchain is baked into the image so it
# needs NO runtime network (egress allow-list unchanged) and NO writable HOME.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      git ca-certificates unzip \
      php-cli php-xml php-mbstring php-curl php-zip \
      composer \
 && rm -rf /var/lib/apt/lists/*

# PHP_CodeSniffer + WordPress Coding Standards baked into a fixed, world-readable
# path. COMPOSER_HOME is scoped to these RUN steps only (not an ENV) so the
# runtime `composer install` defaults back to $HOME/.composer (the writable tmpfs
# HOME), never the read-only /opt path. WPCS pulls in the phpcodesniffer-composer
# -installer plugin (registers the standard into phpcs's installed_paths); it
# must be allow-listed before install. The plugin wires installed_paths into the
# phpcs package dir, so `phpcs --standard=WordPress` resolves with no network and
# runs fine as the §11.1 uid 65532 (--read-only, --cap-drop=ALL).
RUN COMPOSER_HOME=/opt/composer composer global config --no-plugins allow-plugins.dealerdirect/phpcodesniffer-composer-installer true \
 && COMPOSER_HOME=/opt/composer composer global require --no-interaction --no-progress \
      squizlabs/php_codesniffer \
      wp-coding-standards/wpcs \
 && ln -s /opt/composer/vendor/bin/phpcs /usr/local/bin/phpcs \
 && ln -s /opt/composer/vendor/bin/phpcbf /usr/local/bin/phpcbf \
 && chmod -R a+rX /opt/composer

RUN npm install -g @anthropic-ai/claude-code

COPY --from=build /out/flow-orchestrator /usr/local/bin/flow-orchestrator

# node user (uid 1000) exists in the base; the §11.1 docker run overrides this
# to 65532 with --user, --read-only, --cap-drop=ALL, --tmpfs, no-new-privileges.
USER node
ENV HOME=/home/node
WORKDIR /work
ENTRYPOINT ["/usr/local/bin/flow-orchestrator"]
