# Flow deploy env (deploy/docker-compose.yml). Copy to .env and fill in.
# NEVER commit a filled-in .env — secrets are references, not values.

# Postgres password for the bundled postgres:16 service.
POSTGRES_PASSWORD=change-me

# Bootstrap tenant name (single-tenant in Vaihe 1).
FLOW_BOOTSTRAP_TENANT=default

# Bootstrap admin GitHub login (§7). Empty => no-op. When set, flowd promotes
# (or creates) this GitHub login as `admin` in the bootstrap tenant at
# startup. Idempotent. This is the only path that mints the first admin —
# afterwards admins manage roles via SQL (or the admin CLI in #9).
FLOW_BOOTSTRAP_ADMIN=

# GitHub token for the central scanner (read-only issue access). Optional in
# Vaihe 1 (empty = anonymous, rate-limited). Per-tenant App broker below
# generalises the bash `github-app-auth.sh` one-triplet model.
FLOW_GITHUB_TOKEN=

# --- §7.3 GitHub App token broker ------------------------------------------
# Pre-shared bearer that gates GET /v1/github-app/token. Empty => endpoint
# returns 503 (fail-closed). Set it to a long random string; runners must
# present it as `Authorization: Bearer <FLOW_BROKER_TOKEN>` — for the bundled
# flow-runner that means deploying with FLOW_RUNNER_TOKEN matching this value.
# Issue #6 landed per-runner tokens for the runner-write endpoints, but this
# broker endpoint still rides the pre-shared bearer; folding it onto runner
# tokens is a follow-up (#8 area), after which this knob disappears.
FLOW_BROKER_TOKEN=
#
# Optional env-bootstrap for the github_app_install registry. Set all four to
# upsert a single (tenant, org) -> installation row at flowd startup; runners
# then GET /v1/github-app/token?org=<ORG>. Add further installations via SQL
# (admin CLI lands in #9). Leave FLOW_GITHUB_APP_ORG empty to skip.
#
# FLOW_GITHUB_APP_PRIVATE_KEY_REF is the NAME of the env var that holds the
# PEM key, never the key itself — the EnvResolver looks it up at mint time
# so secrets stay out of the DB.
FLOW_GITHUB_APP_ORG=
FLOW_GITHUB_APP_ID=
FLOW_GITHUB_APP_INSTALLATION_ID=
FLOW_GITHUB_APP_PRIVATE_KEY_REF=
# Example: set FLOW_GITHUB_APP_PRIVATE_KEY_REF=FLOW_GITHUB_APP_KEY_DEFAULT and
# put the PEM body in FLOW_GITHUB_APP_KEY_DEFAULT (multi-line PEMs go inline
# with escaped \n or via Docker secret mount).
# FLOW_GITHUB_APP_KEY_DEFAULT="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub OAuth App client_id used for the §7(a) device flow (`flowctl login`).
# Register an OAuth App at https://github.com/settings/developers (User
# authorization callback URL is irrelevant for device flow but required by the
# GitHub form — use the central's URL). Device flow needs only the client_id,
# no client_secret. Leave empty to disable `flowctl login` (the central returns
# 503 on /v1/auth/device/* and existing endpoints keep working).
FLOW_GITHUB_OAUTH_CLIENT_ID=

# Scanner poll interval (Go duration, e.g. 60s, 2m).
FLOW_SCAN_INTERVAL=60s

# Runner token (§7(b)). The host daemon mints a fresh one at `runner register`
# and uses it automatically, so this seed value is normally left empty. It IS
# required inside the per-run orchestrator container, where runnerexec injects
# the minted token under this name — the runner-write endpoints (lease, run
# telemetry, heartbeats) reject requests without a valid runner token.
FLOW_RUNNER_TOKEN=

# Runner work-pull interval.
FLOW_POLL_INTERVAL=15s

# Runner dispatch mode (§11.1): `container` launches each run inside a hardened
# ephemeral flow-orchestrator container; `inproc` keeps orchestration in the
# runner process (dev default; no Docker required on the dev box).
FLOW_RUNNER_MODE=container

# Image used for the per-run orchestrator container (built from
# deploy/Dockerfile.orchestrator).
FLOW_ORCHESTRATOR_IMAGE=flow-orchestrator:latest

# Logical runner name; selects the per-runner egress network (egress proxy).
FLOW_RUNNER_NAME=

# Egress proxy URL injected into the per-run container (§11.2). Empty = no proxy
# (dev). In production this routes container egress through the allow-list proxy.
FLOW_EGRESS_PROXY=

# Per-run container resource limits passed to `docker run` (§11.1). Empty = no
# explicit limit. Memory accepts Docker units (e.g. 2g, 512m); CPUs is a decimal
# core count (e.g. 1.5).
FLOW_CONTAINER_MEMORY=
FLOW_CONTAINER_CPUS=

# Host path to the Claude credential file (Model B, §11.5). Mounted READ-ONLY
# into the per-run container; never an env var, never seen by the central
# service. Leave empty to skip the mount (dev / no-Claude runs).
FLOW_CLAUDE_CRED_PATH=

# §11.6 egress shipper: path to the squid access.log inside the flow-runner
# container. Empty disables the shipper (dev boxes without the proxy sidecar).
# The deploy compose file wires this to the shared egress-log named volume.
FLOW_EGRESS_LOG=/var/log/squid/access.log
